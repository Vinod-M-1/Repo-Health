<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Repo Health Auditor</title>
    <style>
        :root {
            --bg-color: #f0f0f0;
            --card-color: #ffffff;
            --accent: #bc95ff; /* Soft Purple */
            --border: #000000;
            --dot-color: #bbbbbb;
        }

        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            background-color: var(--bg-color);
            background-image: radial-gradient(var(--dot-color) 1px, transparent 1px);
            background-size: 20px 20px;
            font-family: 'Public Sans', 'Segoe UI', sans-serif;
        }

        .container {
            background: var(--card-color);
            padding: 40px;
            border: 3px solid var(--border);
            box-shadow: 10px 10px 0px 0px var(--border);
            max-width: 600px;
            width: 90%;
            text-align: center;
        }

        h1 {
            font-size: 3rem;
            margin: 0 0 10px 0;
            font-weight: 900;
            text-transform: uppercase;
        }

        .subtitle {
            font-size: 1.1rem;
            color: #555;
            margin-bottom: 40px;
            line-height: 1.4;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        input[type="text"] {
            padding: 18px;
            font-size: 1rem;
            border: 3px solid var(--border);
            background: #fff;
            outline: none;
        }

        button {
            padding: 18px;
            font-size: 1.1rem;
            font-weight: 800;
            background: var(--accent);
            border: 3px solid var(--border);
            cursor: pointer;
            box-shadow: 5px 5px 0px var(--border);
            transition: all 0.1s;
            text-transform: uppercase;
        }

        button:active {
            transform: translate(2px, 2px);
            box-shadow: 3px 3px 0px var(--border);
        }

        .footer {
            margin-top: 30px;
            font-weight: 700;
            font-size: 0.9rem;
        }

        @media (min-width: 600px) {
            .form-group { flex-direction: row; }
            input[type="text"] { flex: 1; }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Repository Analysis</h1>
        <p class="subtitle">Analyze any GitHub repository complexity and project health metrics: </p>
        <form action="/analyse" method="get">
            <div class="form-group">
                <input type="text" name="url" placeholder="https://github.com/username/repo" required>
                <button type="submit">Analyze →</button>
            </div>
        </form>
    </div>
    <div class="footer">Made by Vinod</div>
</body>
</html>