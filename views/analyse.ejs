<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analysis Report | Repo Health</title>
    <style>
        :root {
            --bg-color: #fdf6ff; /* Soft Lavender Tint */
            --card-white: #ffffff;
            --border: #000000;
            --dot-color: #d1d5db;
            /* Pastel Palette for Metrics */
            --pink: #ffc2e2;
            --yellow: #fff3c2;
            --green: #c2ffd1;
            --blue: #c2e9ff;
        }

        body {
            margin: 0;
            padding: 40px 20px;
            background-color: var(--bg-color);
            background-image: radial-gradient(var(--dot-color) 1.5px, transparent 1.5px);
            background-size: 25px 25px;
            font-family: 'Public Sans', 'Segoe UI', sans-serif;
            color: var(--border);
        }

        h1 {
            text-align: center;
            font-size: clamp(2rem, 6vw, 3.5rem);
            font-weight: 900;
            text-transform: uppercase;
            margin: 0;
        }

        .repo-path {
            text-align: center;
            margin: 10px 0 40px 0;
            font-weight: 600;
            color: #666;
            word-break: break-all;
        }

        /* SUMMARY DASHBOARD */
        .summary-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 50px;
        }

        .summary-card {
            border: 3px solid var(--border);
            padding: 25px;
            text-align: center;
            box-shadow: 8px 8px 0px 0px var(--border);
        }

        /* Different colors for each summary box */
        .summary-card:nth-child(1) { background: var(--pink); }
        .summary-card:nth-child(2) { background: var(--yellow); }
        .summary-card:nth-child(3) { background: var(--green); }
        .summary-card:nth-child(4) { background: var(--blue); }

        .summary-label {
            font-size: 13px;
            text-transform: uppercase;
            font-weight: 800;
            margin-bottom: 8px;
            letter-spacing: 1px;
        }

        .summary-value {
            font-size: 28px;
            font-weight: 900;
        }

        /* INDIVIDUAL FILE CARDS */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 30px;
        }

        .file-card {
            background: var(--card-white);
            border: 3px solid var(--border);
            padding: 25px;
            box-shadow: 10px 10px 0px 0px var(--border);
            display: flex;
            flex-direction: column;
        }

        .file-header {
            font-size: 1.1rem;
            font-weight: 900;
            margin-bottom: 15px;
            border-bottom: 3px solid var(--border);
            padding-bottom: 10px;
            word-break: break-all;
        }

        .stat-group {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .stat-pill {
            background: #fff;
            border: 2px solid var(--border);
            padding: 5px 12px;
            font-size: 12px;
            font-weight: 800;
            box-shadow: 3px 3px 0px var(--border);
        }

        .functions-area {
            flex-grow: 1;
        }

        .function-item {
            background: #f9f9f9;
            border: 2px solid #eee;
            padding: 10px;
            margin-top: 8px;
            font-size: 13px;
        }

        .func-title { font-weight: 900; color: #000; }

        @media (max-width: 600px) {
            body { padding: 20px 15px; }
            .summary-card { padding: 15px; }
        }
    </style>
</head>
<body>

    <h1>Analysis Report</h1>
    <div class="repo-path"> <%= repo %></div>

    <div class="summary-container">
        <div class="summary-card">
            <div class="summary-label">Project Scale</div>
            <div class="summary-value"><%= summary.projectScale %></div>
        </div>
        <div class="summary-card">
            <div class="summary-label">Maintainability</div>
            <div class="summary-value"><%= summary.avgMaintainability %>%</div>
        </div>
        <div class="summary-card">
            <div class="summary-label">Issue Density</div>
            <div class="summary-value"><%= summary.issueDensity %></div>
        </div>
        <div class="summary-card">
            <div class="summary-label">Total Files</div>
            <div class="summary-value"><%= summary.totalFiles %></div>
        </div>
    </div>

    <div class="grid">
        <% files.forEach(file => { %>
            <div class="file-card">
                <div class="file-header">📄 <%= file.file.split('/').pop() %></div>
                
                <div class="stat-group">
                    <div class="stat-pill">LOC: <%= file.linesofcode %></div>
                    <div class="stat-pill">MI: <%= file.mi.toFixed(1) %></div>
                    <div class="stat-pill">CC: <%= file.complexity %></div>
                </div>

                <div class="functions-area">
                    <strong>Functions Detected:</strong>
                    <% file.Cyclometric.funs.forEach(fun => { %>
                        <div class="function-item">
                            <div class="func-title"><%= fun.name %></div>
                            Complexity: <%= fun.counter %> | Depth: <%= fun.depth %>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% }) %>
    </div>

</body>
</html>