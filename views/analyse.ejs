<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Repository Analysis</title>

<style>

:root{
--bg:#e8f7ff;
--card:#cfefff;
--accent:#5fd3ff;
--border:#000;
}

body{
margin:0;
font-family:Segoe UI, sans-serif;
background:var(--bg);
padding:40px;
}

h1{
text-align:center;
font-size:40px;
margin-bottom:10px;
}

.repo{
text-align:center;
margin-bottom:40px;
font-weight:500;
}

/* GRID */

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
gap:30px;
}

/* CARD */

.card{

background:var(--card);

border:3px solid var(--border);
border-radius:12px;

padding:25px;

box-shadow:8px 8px 0px black;

}

.file{
font-size:18px;
font-weight:bold;
margin-bottom:15px;
word-break:break-all;
}

.stats{
display:flex;
justify-content:space-between;
margin-bottom:15px;
}

.stat{
background:var(--accent);
border:2px solid black;
padding:6px 10px;
border-radius:6px;
font-weight:bold;
box-shadow:3px 3px 0px black;
}

.functions{
margin-top:15px;
}

.func{
background:white;
border:2px solid black;
border-radius:6px;
padding:8px;
margin-top:6px;
font-size:14px;
}

.func span{
font-weight:bold;
}
.summary-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
}

.summary-card {
    background: #fff;
    border: 3px solid black;
    border-radius: 12px;
    padding: 20px;
    text-align: center;
    box-shadow: 6px 6px 0px #000;
}

.summary-label { font-size: 14px; text-transform: uppercase; color: #666; margin-bottom: 5px; }
.summary-value { font-size: 24px; font-weight: bold; color: #007bff; }

</style>

</head>

<body>

<h1>Repository Analysis</h1>

<div class="repo">
Repository: <%= repo %>
</div>
<div class="summary-container">
    <div class="summary-card">
        <div class="summary-label">Project Scale</div>
        <div class="summary-value"><%= summary.projectScale %></div>
    </div>

    <div class="summary-card">
        <div class="summary-label">Avg Maintainability</div>
        <div class="summary-value"><%= summary.avgMaintainability %>%</div>
    </div>

    <div class="summary-card">
        <div class="summary-label">Issue Density</div>
        <div class="summary-value"><%= summary.issueDensity %></div>
    </div>

    <div class="summary-card">
        <div class="summary-label">Total JS Files</div>
        <div class="summary-value"><%= summary.totalFiles %></div>
    </div>
</div>

<div class="grid">

<% files.forEach(file => { %>

<div class="card">

<div class="file">
📁 <%= file.file %>
</div>

<div class="stats">

<div class="stat">
LOC: <%= file.linesofcode %>
</div>

<div class="stat">
MI: <%= file.mi.toFixed(1) %>
</div>

<div class="stat">
CC: <%= file.complexity %>
</div>

</div>

<div class="functions">

<strong>Functions</strong>

<% file.Cyclometric.funs.forEach(fun => { %>

<div class="func">

<span><%= fun.name %></span>

<br>

Complexity: <%= fun.counter %> |
Depth: <%= fun.depth %> |
LOC: <%= fun.loc %>

</div>

<% }) %>

</div>

</div>

<% }) %>

</div>

</body>
</html>